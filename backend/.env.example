# AMR Health - Environment Configuration
# Copy to .env and adjust values. Shares the same PostgreSQL as SiteOps.

# Connect to the SAME Postgres as SiteOps (shared DB is the integration bridge).
DATABASE_URL=postgres://amr:amr@localhost:5432/amrdashboard?sslmode=disable
PORT=8090

# Must match SiteOps ENCRYPTION_KEY (used to decrypt SSH credentials from shared servers table).
ENCRYPTION_KEY=change-this-to-a-32-byte-secret!!
SESSION_SECRET=change-this-to-a-long-random-session-secret

# Admin login (for protected routes like sync management).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password

# Log sync schedule (independent from SiteOps).
SCHEDULE_AM=0 6 * * *
SCHEDULE_PM=0 18 * * *
SYNC_ON_STARTUP=true
SYNC_STARTUP_DELAY_SECONDS=20

# LLM for agent diagnosis.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
LLM_API_KEY=

# CORS: allow AMR Health frontend + SiteOps frontend.
ALLOWED_ORIGINS=http://localhost:8090,http://localhost:3000,http://localhost:8088

# Agent snapshot interval (minutes).
AGENT_SNAPSHOT_MINUTES=15
