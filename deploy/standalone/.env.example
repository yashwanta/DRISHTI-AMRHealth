# Copy this file to .env and replace every CHANGE_ME value.
POSTGRES_USER=drishti
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
POSTGRES_DB=drishti
DATABASE_URL=postgres://drishti:CHANGE_ME_URL_ENCODED_PASSWORD@database:5432/drishti?sslmode=disable
ENCRYPTION_KEY=CHANGE_ME_EXISTING_32_BYTE_KEY
SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SESSION_SECRET
ALLOWED_ORIGINS=http://localhost:8099
AMR_HEALTH_PORT=8099

# Optional live RDS fallback used by Discovery.
DRISHTI_DISCOVERY_RDS_BASE_URL=
DRISHTI_DISCOVERY_RDS_SESSION_TOKEN=

# OpenAI-compatible LLM used by Agent Findings and timeline summaries.
# Keep LLM_API_KEY only in the private .env file.
OLLAMA_URL=https://llm.eidonix.com
OLLAMA_MODEL=deepseek-v4-pro
LLM_API_KEY=
